# 复制为 .env.local（勿提交仓库）
#
# 本地跑 TTS：在项目根执行 npm run dev:vercel，CLI 会读取本文件中的变量。
KOKORO_API_KEY=

# 默认已指向 …/v1/audio/speech；若你的 Space 使用其它路径，在此覆盖完整 URL：
# KOKORO_TTS_URL=https://你的-space.hf.space/自定义路径

# 链接抽正文 /api/url-extract（默认每 IP 15 次 / 60 秒）
# URL_EXTRACT_IP_RATE_LIMIT_MAX=15
# URL_EXTRACT_IP_RATE_WINDOW_SEC=60
